{
  "name": "siroto-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --prefix backend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "install:all": "npm install && npm install --prefix backend",
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
